    {
      "parameters": {
        "content": "PRO KUNDE ANPASSEN:\n1. Node Lead-ID: makler_slug setzen\n2. Node Makler Mail: sendTo auf Makler-E-Mail\n3. Alle Leads holen Nodes: MAKLER_ID anpassen\n\nMAILGUN (spaeter):\nGmail-Nodes durch Mailgun-Nodes ersetzen"
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-250, -400],
      "id": "sticky-01",
      "name": "Setup Hinweise"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "makler_tally",
        "options": {}
      },
