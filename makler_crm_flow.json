      "typeVersion": 2.1,
      "position": [0, 0],
      "id": "node-01",
      "name": "Webhook",
      "webhookId": "3c8170a7-c486-443a-b7cf-e6b32d098095"
    },
    {
      "parameters": {
        "jsCode": "const fields = $json.body.data.fields;\n\nconst getByKey = (key) => {\n  const f = fields.find(f => f.key === key);\n  if (!f || f.value === null) return null;\n  if (Array.isArray(f.value)) {\n    if (f.value.length === 0) return null;\n    return f.value.map(id => f.options?.find(o => o.id === id)?.text).filter(Boolean).join(', ');\n  }\n  return f.value;\n};\n\nconst objekttyp = getByKey('question_AJrWLy') || getByKey('question_eA5990') || getByKey('question_WoJllj') || null;\n\nreturn [{\n  json: {\n    name:         getByKey('question_axOZYZ'),\n    email:        getByKey('question_6kDr2A'),\n    telefon:      getByKey('question_7DX42a'),\n    service:      getByKey('question_bkZNx6'),\n    objekttyp,\n    budget:       getByKey('question_B1E8ke'),\n    zeitrahmen:   getByKey('question_kAbO6r'),\n    region:       getByKey('question_vBXqyg'),\n    nachricht:    getByKey('question_Kop8lg'),\n    submissionId: $json.body.data.submissionId,\n    formId:       $json.body.data.formId,\n    createdAt:    $json.body.data.createdAt\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [250, 0],
      "id": "node-02",
      "name": "Daten parsen"
    },
    {
      "parameters": {
        "jsCode": "const now = Date.now().toString(36).toUpperCase();\nconst rnd = Math.random().toString(36).slice(2, 6).toUpperCase();\nreturn [{\n  json: {\n    ...$input.first().json,\n    lead_id: 'LEAD-' + now + '-' + rnd,\n    makler_slug: 'MAKLER_ID'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 0],
      "id": "node-03",
      "name": "Lead-ID"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "role": "system",
              "content": "Du bist ein erfahrener Lead-Qualifizierungs-Assistent fuer Immobilienmakler in Deutschland. Analysiere Leads praezise und professionell. Antworte NUR mit validem JSON, kein Text drumherum."
            },
            {
              "content": "=Analysiere diesen Immobilien-Lead:\n\nName: {{ $json.name }}\nService: {{ $json.service }}\nObjekttyp: {{ $json.objekttyp }}\nBudget: {{ $json.budget }}\nZeitrahmen: {{ $json.zeitrahmen }}\nRegion: {{ $json.region }}\nNachricht: {{ $json.nachricht }}\n\nGib zurueck:\n{\n  \"score\": (1-100),\n  \"score_begruendung\": \"praezise Begruendung\",\n  \"prioritaet\": \"Hoch|Mittel|Niedrig\",\n  \"naechster_schritt\": \"konkreter naechster Schritt fuer den Makler\",\n  \"zusammenfassung\": \"3-4 Saetze: wer ist der Lead, was sucht er, wie ernst ist er\"\n}"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [750, 0],
      "id": "node-04",
      "name": "GPT Qualifizierung",
      "credentials": {
        "openAiApi": {
          "id": "yPd0z65r12rtD5ip",
          "name": "OpenAi account 3"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.output[0].content[0].text;\nconst ai = JSON.parse(text);\nreturn [{\n  json: {\n    ...$('Lead-ID').first().json,\n    score:             ai.score,\n    score_begruendung: ai.score_begruendung,\n    prioritaet:        ai.prioritaet,\n    naechster_schritt: ai.naechster_schritt,\n    zusammenfassung:   ai.zusammenfassung\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 0],
      "id": "node-05",
      "name": "GPT Parsen"
    },
